datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
generator client {
  provider = "prisma-client-js"
}

model VestingSchedule {
  id          String   @id @default(uuid())
  grantor     String
  beneficiary String
  amount      Float
  status      String
  startTime   DateTime @default(now())
  endTime     DateTime
}

model Proposal {
  id        String   @id @default(uuid())
  proposer  String
  title     String
  amount    Float
  status    String
  votes     Vote[]
  createdAt DateTime @default(now())
}

model Vote {
  id         String   @id @default(uuid())
  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id])
  voter      String
  support    Boolean
  weight     Float
  createdAt  DateTime @default(now())
}

model Stream {
  id               String       @id @default(uuid())
  contractStreamId Int          @unique
  sender           String
  recipient        String
  token            String
  totalAmount      Float
  claimedAmount    Float        @default(0)
  startTime        DateTime
  endTime          DateTime
  status           String       @default("Active")
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  claimHistory     ClaimEvent[]
}

model ClaimEvent {
  id        String   @id @default(uuid())
  streamId  String
  stream    Stream   @relation(fields: [streamId], references: [id])
  amount    Float
  timestamp DateTime @default(now())
}

model TreasuryEvent {
  id              String   @id @default(uuid())
  treasuryAddress String
  eventType       String
  address         String?
  amount          Float?
  proposalId      Int?
  metadata        Json?
  timestamp       DateTime @default(now())
}
