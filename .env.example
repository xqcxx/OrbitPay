POSTGRES_DB=orbitpay
POSTGRES_USER=orbitpay
POSTGRES_PASSWORD=orbitpay

API_PORT=3001
INDEXER_PORT=3002

DATABASE_URL=postgresql://orbitpay:orbitpay@postgres:5432/orbitpay?schema=public
REDIS_URL=redis://redis:6379

RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_BACKOFF_BASE_SECONDS=60

INDEXER_POLL_INTERVAL_MS=5000
